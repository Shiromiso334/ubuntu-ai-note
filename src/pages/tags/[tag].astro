---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tagSet = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			tagSet.add(tag);
		}
	}
	return [...tagSet].map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((p) => p.data.tags?.includes(tag))
				.sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99)),
		},
	}));
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`「${tag}」の記事一覧 | Ubuntu×AI実践ノート`}
			description={`タグ「${tag}」がついた記事の一覧です。`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<p class="back"><a href="/tags/">← タグ一覧へ</a></p>
			<h1>「{tag}」の記事一覧</h1>
			<p class="count">{posts.length}件</p>
			<ul class="article-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						<p>{post.data.description}</p>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 720px;
		margin: 4em auto;
		padding: 0 1em;
		box-sizing: border-box;
	}
	.back a {
		text-decoration: none;
		color: rgb(var(--gray));
		font-size: 0.9em;
	}
	.back a:hover {
		color: var(--accent);
	}
	h1 {
		font-size: 1.5em;
		margin: 0.5em 0 0.25em;
	}
	.count {
		color: rgb(var(--gray));
		font-size: 0.9em;
		margin: 0 0 1.5em;
	}
	.article-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75em;
	}
	.article-list li {
		padding: 1em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		min-width: 0;
		overflow-wrap: break-word;
		word-break: break-word;
	}
	.article-list a {
		display: block;
		font-weight: bold;
		text-decoration: none;
		color: var(--accent);
		margin-bottom: 0.3em;
		overflow-wrap: break-word;
		word-break: break-word;
	}
	.article-list a:hover {
		text-decoration: underline;
	}
	.article-list p {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: 0;
		overflow-wrap: break-word;
	}
	@media (max-width: 720px) {
		main {
			margin: 1.5em auto;
		}
		h1 {
			font-size: 1.25em;
			word-break: break-word;
		}
		.article-list li {
			padding: 0.8em 0.9em;
		}
		.article-list a {
			font-size: 0.92em;
			line-height: 1.4;
		}
	}
</style>
