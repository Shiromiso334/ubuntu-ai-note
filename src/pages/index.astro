---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{SITE_TITLE}</h1>
			<p class="description">{SITE_DESCRIPTION}</p>

			<section class="featured">
				<p class="featured-label">最初に読む記事</p>
				<a href="/blog/ubuntu-claude-code-setup" class="featured-link">
					UbuntuにClaude Codeを導入してAI作業環境を整える手順
				</a>
				<p class="featured-desc">UbuntuへのClaude Codeのインストールから初期設定まで、つまずきポイントも含めて手順をまとめた記事です。</p>
			</section>

			<nav class="top-links">
				<a href="/blog">ブログ記事一覧へ</a>
				<a href="/about">このブログについて</a>
				<a href="/contact">お問い合わせ</a>
				<a href="/privacy">プライバシーポリシー</a>
			</nav>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 4em auto;
		padding: 0 1em;
		text-align: center;
	}
	h1 {
		font-size: 2em;
		margin-bottom: 0.5em;
	}
	.description {
		color: rgb(var(--gray));
		margin-bottom: 2em;
	}
	.featured {
		margin-bottom: 2.5em;
		padding: 1.25em 1.5em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		text-align: left;
	}
	.featured-label {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0 0 0.4em;
	}
	.featured-link {
		display: block;
		font-size: 1.05em;
		font-weight: bold;
		text-decoration: none;
		color: var(--accent);
		margin-bottom: 0.5em;
	}
	.featured-link:hover {
		text-decoration: underline;
	}
	.featured-desc {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: 0;
	}
	.top-links {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
		align-items: center;
	}
	.top-links a {
		display: inline-block;
		padding: 0.5em 1.5em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 4px;
		text-decoration: none;
		color: var(--black);
		width: 16em;
	}
	.top-links a:hover {
		background: rgb(var(--gray-light));
	}
</style>
